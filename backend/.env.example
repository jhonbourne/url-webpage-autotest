# Copy to .env and fill in. All variables are read by app/core/config.py (pydantic-settings).

# --- LLM ---
# Default provider: openai | claude | gemini | cohere | ollama
LLM_PROVIDER=claude
# Overrides the provider's built-in default model
LLM_MODEL=claude-sonnet-5
# The anthropic SDK reads this automatically; keep it out of source control.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Server ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
DEBUG=false

# --- Fetching ---
FETCH_TIMEOUT_MS=30000
# Reject requests that resolve to private/loopback addresses (SSRF guard)
BLOCK_PRIVATE_ADDRESSES=true
