# Copy to .env and fill in. All variables are read by app/core/config.py (pydantic-settings).

# --- LLM ---
# Provider: dashscope (Aliyun, OpenAI-compatible) | claude
LLM_PROVIDER=dashscope
DASHSCOPE_API_KEY=sk-...
# International endpoint alternative:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Role-based models. Prefer qwen3-*; if a size is unavailable, move up a version
# (qwen3.5-* -> higher). Confirm exact model IDs in your DashScope console.
#
# Profile A — logic / plumbing tests (small, cheap; just verify the pipeline runs):
LLM_MODEL=qwen3-8b
LLM_CODE_MODEL=qwen3-coder-30b-a3b-instruct
#
# Profile B — agent performance eval (large; measure real extraction quality):
#LLM_MODEL=qwen3-235b-a22b
#LLM_CODE_MODEL=qwen3-coder-480b-a35b-instruct

# Alternative provider (only used when LLM_PROVIDER=claude):
#ANTHROPIC_API_KEY=sk-ant-...

# --- Extraction quality / reflection loop ---
MAX_EXTRACTION_RETRIES=2
MIN_FIELD_COVERAGE=0.5

# --- Server ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
DEBUG=false

# --- Fetching ---
FETCH_TIMEOUT_MS=30000
# Reject requests that resolve to private/loopback addresses (SSRF guard)
BLOCK_PRIVATE_ADDRESSES=true
